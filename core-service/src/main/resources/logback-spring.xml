<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>request_id</includeMdcKeyName>
            <customFields>{"service":"core-service"}</customFields>
        </encoder>
    </appender>

    <!-- Use Spring profile to switch between plain console (dev) and JSON (prod) if desired, 
         but for consistency we output JSON globally here. -->
    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE" />
    </root>

    <logger name="com.feexray" level="DEBUG" />
</configuration>
